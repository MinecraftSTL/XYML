{
  "$schema": "https://schemas.glavo.site/hmcl/theme-pack/1.0.0",
  "id": "hmcl.default",
  "version": "1.0.0",
  "name": {
    "default": "Default",
    "zh-Hans": "默认主题",
    "zh-Hant": "預設主題"
  },
  "description": {
    "default": "XYML Default",
    "zh-Hans": "XYML 默认主题",
    "zh-Hant": "XYML 預設主題"
  },
  "authors": [
    {
      "name": "XYML"
    }
  ],
  "theme": {
    "color": "#6B69D6",
